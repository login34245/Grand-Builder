  "message.grand_builder.capture_exported": "\u042d\u043a\u0441\u043f\u043e\u0440\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u043e \u043a\u0430\u043a %s: %s \u0444\u0430\u0439\u043b(\u043e\u0432). \u041f\u0443\u0442\u044c: %s",
  "message.grand_builder.capture_export_failed": "\u0421\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u0430 \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0430 \u0434\u043b\u044f \u044d\u0442\u043e\u0439 \u0441\u0435\u0441\u0441\u0438\u0438, \u043d\u043e \u044d\u043a\u0441\u043f\u043e\u0440\u0442 \u0432 \u0444\u0430\u0439\u043b \u043d\u0435 \u0443\u0434\u0430\u043b\u0441\u044f. \u041f\u0440\u043e\u0432\u0435\u0440\u044c \u043b\u043e\u0433 \u0441\u0435\u0440\u0432\u0435\u0440\u0430.",
  "message.grand_builder.capture_tool_required": "\u0414\u0435\u0440\u0436\u0438 \u042f\u0434\u0440\u043e \u0441\u0442\u0440\u043e\u0438\u0442\u0435\u043b\u044f \u0438\u043b\u0438 \u0421\u0435\u043b\u0435\u043a\u0442\u043e\u0440 \u0441\u0442\u0440\u043e\u0438\u0442\u0435\u043b\u044f, \u0447\u0442\u043e\u0431\u044b \u0441\u043e\u0445\u0440\u0430\u043d\u0438\u0442\u044c \u0441\u0432\u043e\u044e \u0441\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u0443."
